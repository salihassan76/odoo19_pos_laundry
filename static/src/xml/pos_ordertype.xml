<?xml version="1.0" encoding="UTF-8"?>
<template id="template" xml:space="preserve">
    <t t-name="pos_laundry.OrderSummaryExtension" t-inherit="point_of_sale.OrderSummary" t-inherit-mode="extension">
        <xpath expr="//OrderDisplay" position="before">
            <div class="laundry-order-info p-2">
                
                    <div class="d-flex justify-content-between">
                        <span><strong>Laundry Type:</strong> <t t-esc="pos.getOrder()?.uiState?.laundry_order_type_name || 'N/A'"/></span>
                        <t t-if="pos.getOrder()?.uiState?.package_rule_id">
                            <div class="mt-1">
                                <strong>Package:</strong>
                                <t t-esc="pos.getOrder()?.uiState?.package_rule_name"/>
                            </div>
                        </t>

                    </div>
                
            </div>
        </xpath>
        
    </t>
</template>