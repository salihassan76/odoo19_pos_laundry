        <!-- Odoo Style Action Buttons -->
<div class="border-top bg-view p-3">

    <div class="row g-3 justify-content-center">

        <!-- Walkin -->
        <div class="col-6 col-md-4 col-xl-2">

            <button class="btn btn-light border w-100 h-100 py-4 shadow-sm"
                    t-on-click="openNewOrder">

                <div class="d-flex flex-column align-items-center">

                    <i class="fa fa-shopping-basket fa-2x text-primary mb-2"/>

                    <span class="fw-bold">
                        Walkin / Normal
                    </span>

                </div>

            </button>

        </div>

        <!-- Express -->
        <div class="col-6 col-md-4 col-xl-2">

            <button class="btn btn-light border w-100 h-100 py-4 shadow-sm"
                    t-on-click="openExpressOrder">

                <div class="d-flex flex-column align-items-center">

                    <i class="fa fa-bolt fa-2x text-danger mb-2"/>

                    <span class="fw-bold">
                        Express
                    </span>

                </div>

            </button>

        </div>

        <!-- Pickup -->
        <div class="col-6 col-md-4 col-xl-2">

            <button class="btn btn-light border w-100 h-100 py-4 shadow-sm"
                    t-on-click="openPickupOrder">

                <div class="d-flex flex-column align-items-center">

                    <i class="fa fa-truck fa-2x text-info mb-2"/>

                    <span class="fw-bold">
                        Home Pickup
                    </span>

                </div>

            </button>

        </div>

        <!-- Delivery -->
        <div class="col-6 col-md-4 col-xl-2">

            <button class="btn btn-light border w-100 h-100 py-4 shadow-sm"
                    t-on-click="openDeliveryOrder">

                <div class="d-flex flex-column align-items-center">

                    <i class="fa fa-home fa-2x text-warning mb-2"/>

                    <span class="fw-bold">
                        Home Delivery
                    </span>

                </div>

            </button>

        </div>

        <!-- Pickup Delivery -->
        <div class="col-6 col-md-4 col-xl-2">

            <button class="btn btn-light border w-100 h-100 py-4 shadow-sm"
                    t-on-click="openPickupDeliveryOrder">

                <div class="d-flex flex-column align-items-center">

                    <i class="fa fa-exchange fa-2x text-dark mb-2"/>

                    <span class="fw-bold">
                        Pickup / Delivery
                    </span>

                </div>

            </button>

        </div>

        <!-- Pending -
        <div class="col-6 col-md-4 col-xl-2">

            <button class="btn btn-light border w-100 h-100 py-4 shadow-sm"
                    t-on-click="openPendingOrders">

                <div class="d-flex flex-column align-items-center">

                    <i class="fa fa-clock-o fa-2x text-secondary mb-2"/>

                    <span class="fw-bold">
                        Pending Orders
                    </span>

                </div>

            </button>

        </div>
        -->

        <!-- Packages -->
        <div class="col-6 col-md-4 col-xl-2">

            <button class="btn btn-light border w-100 h-100 py-4 shadow-sm"
                    t-on-click="openNewSubscription">

                <div class="d-flex flex-column align-items-center">

                    <i class="fa fa-gift fa-2x text-success mb-2"/>

                    <span class="fw-bold">
                        Package Subscription
                    </span>

                </div>

            </button>

        </div>

    </div>

</div>

