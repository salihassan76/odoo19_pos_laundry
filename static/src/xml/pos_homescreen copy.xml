<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="pos_laundry.pos_homescreen">

    <div class="d-flex flex-column h-100 p-4 bg-100">

        
        <div class="d-flex flex-column h-100 p-4 bg-100">
            <!-- Search Area -->
            <div class="controls d-flex justify-content-center p-2 border-bottom bg-view">
                <div class="pos-search-bar d-flex align-items-center rounded w-100"
                    style="max-width: 700px;">

                    <div class="search position-relative h-100 d-flex flex-grow-1">
                        <div class="input-group">

                            <span class="input-group-text">
                                <i class="fa-fw oi oi-search"
                                role="img"
                                aria-label="Search Products"
                                title="Search Products"/>
                            </span>

                            <input class="form-control form-control-lg"
                                type="text"
                                placeholder="Search Customer,Orders..."/>

                        </div>
                    </div>

                </div>

            </div>

            <!-- Customer Details -->
            <div class="overflow-y-auto flex-grow-1 rounded-bottom-3 bg-view p-4">

                <div class="d-flex justify-content-center">

                    <div class="card shadow-sm border-0 w-100"
                        style="max-width: 1000px;">

                        <div class="card-body">

                            <div class="overflow-y-auto flex-grow-1 rounded-bottom-3 bg-view p-3">

                                <div class="o_form_sheet_bg">
                                    <div class="o_form_sheet p-4 mx-auto" style="max-width: 1000px;">


                                        <!-- Customer Header -->
