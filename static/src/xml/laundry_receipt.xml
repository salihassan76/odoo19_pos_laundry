<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_laundry.LaundryReceipt">
        <div class="pos-receipt">

            <div class="pos-receipt-center-align">
                <h3><t t-esc="receipt.company_name"/></h3>
                <div t-if="receipt.company_phone">
                    <t t-esc="receipt.company_phone"/>
                </div>
            </div>

            <br/>

            <div>Order: <t t-esc="receipt.order_name"/></div>
            <div>Date: <t t-esc="receipt.date"/></div>
            <div>Customer: <t t-esc="receipt.customer_name"/></div>
            <div t-if="receipt.customer_phone">
                Mobile: <t t-esc="receipt.customer_phone"/>
            </div>
            <div>Type: <t t-esc="receipt.order_type"/></div>

            <hr/>

            <table class="receipt-orderlines">
                <tbody>

                    <t t-foreach="receipt.services" t-as="service" t-key="service.name">

                        <tr>
                            <td colspan="3">
                                <strong>
                                    <t t-esc="service.name"/>
                                </strong>
                            </td>
                        </tr>

                        <tr t-foreach="service.lines"
                            t-as="line"
                            t-key="line.product_name">

                            <td>
                                <t t-esc="line.product_name"/>
                            </td>

                            <td class="pos-receipt-center-align">
                                <t t-esc="line.qty"/>
                            </td>

                            <td class="pos-receipt-right-align">
                                <t t-esc="line.subtotal"/>
                            </td>

                        </tr>

                    </t>

                </tbody>
            </table>

            <hr/>

            <div class="pos-receipt-right-align">
                <strong>Total: <t t-esc="receipt.total"/></strong>
            </div>

            <br/>

            <t t-if="receipt.is_package_sale">
                <div class="pos-receipt-center-align">
                    <strong>PACKAGE PURCHASE</strong>
                </div>
            </t>

            <t t-if="receipt.is_package_usage">
                <div class="pos-receipt-center-align">
                    <strong>PAID BY PACKAGE</strong>
                </div>
            </t>

            <div>
                Payment:
                <strong><t t-esc="receipt.payment_status"/></strong>
            </div>

            <div>
                Status:
                <strong><t t-esc="receipt.status"/></strong>
            </div>

            <t t-if="receipt.note">
                <hr/>
                <div><strong>Notes:</strong></div>
                <div><t t-esc="receipt.note"/></div>
            </t>

            <hr/>

            <div class="pos-receipt-center-align">
                Thank You
            </div>

        </div>
    </t>

</templates>