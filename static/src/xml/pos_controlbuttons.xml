<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="pos_laundry.ControlButtons"
       t-inherit="point_of_sale.ControlButtons"
       t-inherit-mode="extension">
       


    <xpath expr="//div[contains(@class, 'control-buttons')]/button[1]"
               position="after">

        <button class="btn btn-secondary btn-lg lh-lg text-truncate w-auto">
        
            <div class="text-truncate text-action">
            Cancel Order
            </div>
        </button>
    </xpath>

</t>

</templates>