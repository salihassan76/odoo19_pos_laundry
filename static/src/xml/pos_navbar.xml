<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="laundry_pos.NavbarExtension"
       t-inherit="point_of_sale.Navbar"
       t-inherit-mode="extension">

        <!-- Hide Register only when laundry workflow is enabled -->
        <xpath expr="//button[hasclass('register-label')]" position="attributes">
            <attribute name="t-if">!pos.config.enable_laundry_workflow</attribute>
        </xpath>

        <!-- Hide Order Tabs only when laundry workflow is enabled -->
        <xpath expr="//div[hasclass('pos-leftheader')]//OrderTabs" position="attributes">
            <attribute name="t-if">!pos.config.enable_laundry_workflow</attribute>
        </xpath>

        <xpath expr="//button[hasclass('orders-button')]" position="attributes">
            <attribute name="t-if">!pos.config.enable_laundry_workflow</attribute>
        </xpath>

        <!-- Replace Orders button content only when laundry workflow is enabled -->
        <xpath expr="//button[hasclass('orders-button')]" position="after">

            <t t-if="pos.config.enable_laundry_workflow">

                <button class="btn btn-light lh-lg d-flex align-items-center justify-content-center gap-2"
                        t-on-click="() => this.pos.navigate('pos_customerscreen')">
                    <i class="fa fa-home text-warning fs-3"/>
                    <span class="d-none d-md-inline">Home</span>
                </button>

                <button class="btn btn-light lh-lg d-flex align-items-center justify-content-center gap-2"
                        t-on-click="() => this.pos.navigate('pos_orderlistscreen')">
                    <i class="fa fa-list-alt text-primary fs-3"/>
                    <span class="d-none d-md-inline">Orders List</span>
                </button>

            </t>

            

        </xpath>

    </t>

</templates>