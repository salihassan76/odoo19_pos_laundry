<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_laundry.CategorySelectorPackageBadge"
       t-inherit="point_of_sale.CategorySelector"
       t-inherit-mode="extension">

        <xpath expr="//div[@class='line-clamp-3']" position="replace">

            <div class="line-clamp-3 d-flex justify-content-between align-items-center"
                 t-att-class="{'w-100': !showCategoryImg(category)}"
                 t-att-style="{'width: 60%;': showCategoryImg(category)}">

                <span t-if="category.name"
                      class="text-center flex-grow-1"
                      t-esc="category.name"/>

                <span
                    t-if="pos.isPackageUsageOrder"
                    class="badge rounded-pill ms-2"
                    t-att-class="{
                        'bg-success': !this.isPackageCategoryDisabled(category.id),
                        'bg-danger': this.isPackageCategoryDisabled(category.id),
                    }"
                    t-esc="this.getPackageCategoryBadge(category.id)"
                />

            </div>

        </xpath>

    </t>

</templates>