<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_laundry.CategorySelectorNativePatch"
       t-inherit="point_of_sale.CategorySelector"
       t-inherit-mode="extension">

        <xpath expr="//t[@t-foreach='this.getCategoriesAndSub()']" position="attributes">
            <attribute name="t-foreach">this.getLaundryCategoriesAndSub()</attribute>
        </xpath>

    </t>

</templates>