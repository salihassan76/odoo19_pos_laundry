<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ==========================================================
         List View
    =========================================================== -->
    <record id="view_laundry_order_list" model="ir.ui.view">
        <field name="name">laundry.order.list</field>
        <field name="model">laundry.order</field>
        <field name="arch" type="xml">
            <list string="Laundry Orders">
                <field name="pos_config_id"/>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="order_type_id"/>
                <field name="order_datetime"/>
                <field name="total_amount"/>
                <field name="payment_status_id"/>
                <field name="status_id"/>
                <field name="pos_order_id"/>
            </list>
        </field>
    </record>

    <!-- ==========================================================
         Form View
    =========================================================== -->
    <record id="view_laundry_order_form" model="ir.ui.view">
        <field name="name">laundry.order.form</field>
        <field name="model">laundry.order</field>
        <field name="arch" type="xml">
            <form string="Laundry Order">
                <sheet>

                    <!-- ==============================
                         Header Information
                    =============================== -->
                    <group>

                        <group string="Order Details">
                            <field name="pos_config_id" readonly="1"/>
                            <field name="name" readonly="1"/>
                            <field name="customer_id"/>
                            <field name="order_type_id"/>
                            <field name="order_datetime" readonly="1"/>
                            <field name="order_date" readonly="1"/>
                            <field name="order_hour" readonly="1"/>
                            <field name="order_weekday" readonly="1"/>
                        </group>

                        <group string="Status and Amount">
                            <field name="status_id"/>
                            <field name="payment_status_id"/>
                            <field name="total_amount" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="pos_order_id" readonly="1"/>
                        </group>

                    </group>

                    <!-- ==============================
                         Tabs
                    =============================== -->
                    <notebook>

                        <!-- Order Lines -->
                        <page string="Order Lines">
                            <field name="order_line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="product_uom_id"/>
                                    <field name="category_id"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- Accounting -->
                        <page string="Accounting">

                            <group>

                                <group string="Invoice">
                                    <field name="invoice_id" readonly="1"/>
                                    <field name="invoice_state" readonly="1"/>
                                    <field name="invoice_payment_state" readonly="1"/>
                                </group>

                            </group>

                        </page>

                        <!-- Cancellation -->
                        <page string="Cancellation"
                              invisible="not cancel_move_id">

                            <group>

                                <group string="Cancellation Details">
                                    <field name="cancel_move_id" readonly="1"/>
                                    <field name="cancel_date" readonly="1"/>
                                    <field name="cancel_user_id" readonly="1"/>
                                </group>

                            </group>

                        </page>

                        <!-- Refund -->
                        <page string="Refund"
                              invisible="not refund_move_id">

                            <group>

                                <group string="Refund Details">
                                    <field name="refund_move_id" readonly="1"/>
                                    <field name="refund_payment_id" readonly="1"/>
                                    <field name="refund_date" readonly="1"/>
                                    <field name="refund_user_id" readonly="1"/>
                                </group>

                            </group>

                        </page>

                        <!-- Notes -->
                        <page string="Notes">
                            <group>
                                <field name="order_note"/>
                                <field name="order_internal_note"/>
                            </group>
                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ==========================================================
         Search View
    =========================================================== -->
    <record id="view_laundry_order_search" model="ir.ui.view">
        <field name="name">laundry.order.search</field>
        <field name="model">laundry.order</field>
        <field name="arch" type="xml">
            <search>

                <field name="pos_config_id"/>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="order_type_id"/>
                <field name="order_date"/>
                <field name="payment_status_id"/>
                <field name="status_id"/>

                <filter
                    name="group_by_pos_config"
                    string="POS"
                    context="{'group_by': 'pos_config_id'}"/>

                <filter
                    name="today"
                    string="Today"
                    domain="[('order_date', '=', context_today())]"/>

                <filter
                    name="has_pos_order"
                    string="Has POS Order"
                    domain="[('pos_order_id', '!=', False)]"/>

                <separator string="Group By"/>

                <filter
                    name="group_by_customer"
                    string="Customer"
                    context="{'group_by': 'customer_id'}"/>

                <filter
                    name="group_by_order_type"
                    string="Order Type"
                    context="{'group_by': 'order_type_id'}"/>

                <filter
                    name="group_by_status"
                    string="Status"
                    context="{'group_by': 'status_id'}"/>

                <filter
                    name="group_by_date"
                    string="Order Date"
                    context="{'group_by': 'order_date'}"/>

            </search>
        </field>
    </record>

</odoo>