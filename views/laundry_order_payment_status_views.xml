<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_laundry_order_payment_status_list" model="ir.ui.view">
        <field name="name">laundry.order.payment.status.list</field>
        <field name="model">laundry.order.payment.status</field>
        <field name="arch" type="xml">
            <list string="Order Payment Status">
                <field name="sequence"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_laundry_order_payment_status_form" model="ir.ui.view">
        <field name="name">laundry.order.payment.status.form</field>
        <field name="model">laundry.order.payment.status</field>
        <field name="arch" type="xml">
            <form string="Order Payment Status">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="sequence"/>
                            
                        </group>

                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_laundry_order_payment_status_search" model="ir.ui.view">
        <field name="name">laundry.order.payment.status.search</field>
        <field name="model">laundry.order.payment.status</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="active"
                        string="Active"
                        domain="[('active','=',True)]"/>
                <filter name="inactive"
                        string="Inactive"
                        domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    
    

</odoo>