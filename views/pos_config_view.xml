<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_pos_config_form_laundry_only" model="ir.ui.view">
        <field name="name">pos.config.form.laundry.only</field>
        <field name="model">pos.config</field>
        <field name="arch" type="xml">

            <form string="Laundry Configuration"
                  create="false"
                  duplicate="false"
                  delete="false">

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <notebook>

                        <page string="General">
                            <group>
                                
                                <field name="direct_print"/>
                                <field name="show_receipt_preview"/>
                            </group>
                        </page>

                        <page string="Orders">
                            <group>
                                <field name="order_status_id"/>
                                <field name="complete_order_status_id"/>
                            </group>
                        </page>

                        <page string="Payments">
                            <group>
                                <field name="unpaid_payment_id"/>
                                <field name="partial_payment_id"/>
                                <field name="paid_payment_id"/>
                                
                                <field name="cancelled_payment_id"/>
                                <field name="refund_payment_id"/>
                            </group>
                        </page>

                        <page string="Project">
                            <group>
                                <field name="is_project"/>
                                <field name="project_id"
                                       invisible="not is_project"
                                       required="is_project"/>
                            </group>
                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>

</odoo>