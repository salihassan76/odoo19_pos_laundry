<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_laundry_configuration_form" model="ir.ui.view">
        <field name="name">laundry.configuration.form</field>
        <field name="model">laundry.configuration</field>
        <field name="arch" type="xml">
            <form string="Laundry Settings">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="package_pos_category_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_laundry_configuration" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">laundry.configuration</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <menuitem id="menu_laundry_settings"
              name="Settings"
              parent="menu_laundry_configuration"
              action="action_laundry_configuration"
              sequence="90"/>

</odoo>