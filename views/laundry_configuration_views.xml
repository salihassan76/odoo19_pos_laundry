<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_laundry_configuration_form" model="ir.ui.view">
        <field name="name">laundry.configuration.form</field>
        <field name="model">laundry.configuration</field>
        <field name="arch" type="xml">
            <form string="Laundry Settings"
                  create="false"
                  duplicate="false"
                  delete="false">
                <sheet>
                    <group string="General Settings">
                        <field name="package_pos_category_id"/>
                        <field name="direct_print"/>
                        <field name="show_receipt_preview"/>
                        
                        
                    </group>
                    <group string="Order Payments">
                        <field name="unpaid_payment_id"/>
                        <field name="partial_payment_id"/>
                        <field name="paid_payment_id"/>
                        <field name="package_payment_id"/>
                        <field name="cancelled_payment_id"/>
                        <field name="refund_payment_id"/>
                    </group>
                    <group string="Project Settings">
                        <field name="is_project"/>
                        <field name="project_id" invisible="not is_project"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_open_laundry_configuration" model="ir.actions.server">
        <field name="name">Laundry Settings</field>
        <field name="model_id" ref="model_laundry_configuration"/>
        <field name="state">code</field>
        <field name="code">action = env['laundry.configuration'].action_open_laundry_configuration()</field>
    </record>

    

</odoo>