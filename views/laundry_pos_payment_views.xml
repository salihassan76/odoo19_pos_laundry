<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_laundry_pos_payment_tree" model="ir.ui.view">
        <field name="name">laundry.pos.payment.tree</field>
        <field name="model">laundry.pos.payment</field>
        <field name="arch" type="xml">
            <list string="Laundry POS Payments">
                <field name="name"/>
                <field name="payment_date"/>
                <field name="laundry_order_id"/>
                <field name="partner_id"/>
                <field name="payment_method_id"/>
                <field name="amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_laundry_pos_payment_form" model="ir.ui.view">
        <field name="name">laundry.pos.payment.form</field>
        <field name="model">laundry.pos.payment</field>
        <field name="arch" type="xml">
            <form string="Laundry POS Payment">

                <header>

                    <button name="action_receive_payment"
                            string="Post Payment"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state != 'posted'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,posted,cancelled"/>

                </header>

                <sheet>

                    <group>

                        <group>
                            <field name="name" readonly="1"/>
                            <field name="laundry_order_id"
                                   readonly="state != 'draft'"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="payment_date"
                                   readonly="state != 'draft'"/>
                            <field name="amount"
                                   readonly="state != 'draft'"/>
                        </group>

                        <group>
                            <field name="pos_config_id" readonly="1"/>
                            <field name="pos_session_id"
                                   readonly="state != 'draft'"/>
                            <field name="cashier_id" readonly="1"/>
                            <field name="payment_method_id"
                                   readonly="state != 'draft'"/>
                            <field name="journal_id"
                                   readonly="state != 'draft'"/>
                        </group>

                    </group>

                    <notebook>

                        <page string="Accounting">

                            <group>
                                <field name="account_payment_id" readonly="1"/>
                            </group>

                        </page>

                        <page string="Notes">

                            <field name="note"
                                   readonly="state != 'draft'"/>

                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_laundry_pos_payment_search" model="ir.ui.view">
        <field name="name">laundry.pos.payment.search</field>
        <field name="model">laundry.pos.payment</field>
        <field name="arch" type="xml">
            <search>

                <field name="name"/>
                <field name="laundry_order_id"/>
                <field name="partner_id"/>

                <filter name="draft"
                        string="Draft"
                        domain="[('state','=','draft')]"/>

                <filter name="posted"
                        string="Posted"
                        domain="[('state','=','posted')]"/>

                <filter name="cancelled"
                        string="Cancelled"
                        domain="[('state','=','cancelled')]"/>

                
                    <filter name="group_partner"
                            string="Customer"
                            context="{'group_by':'partner_id'}"/>
                    <filter name="group_payment_method"
                            string="Payment Method"
                            context="{'group_by':'payment_method_id'}"/>
                    <filter name="group_pos_session"
                            string="POS Session"
                            context="{'group_by':'pos_session_id'}"/>
                    <filter name="group_state"
                            string="State"
                            context="{'group_by':'state'}"/>
                

            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_laundry_pos_payment" model="ir.actions.act_window">
        <field name="name">POS Payments</field>
        <field name="res_model">laundry.pos.payment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_laundry_pos_payment_search"/>
    </record>

</odoo>