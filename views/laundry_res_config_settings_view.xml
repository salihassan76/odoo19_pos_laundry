<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<record id="res_config_settings_view_form_pos_laundry" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.pos.laundry</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.res_config_settings_view_form"/>
    <field name="arch" type="xml">

        <xpath expr="//form" position="inside">
            <app string="Laundry POS" name="pos_laundry">
                <block title="Package Settings">
                    <setting string="Package POS Category">
                        <field name="laundry_package_category_id"/>
                    </setting>
                </block>
            </app>
        </xpath>

    </field>
</record>
</odoo>