<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="res_config_settings_view_form_laundry_pos" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.laundry.pos</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//setting[@id='is_restaurant']" position="after">

                <setting id="is_laundry_workflow"
                         string="Laundry Workflow"
                         help="Enable the Laundry workflow for the selected Point of Sale.">

                    <field name="pos_enable_laundry_workflow"/>

                    <div class="content-group mt16"
                         invisible="not pos_enable_laundry_workflow">

                        <div class="row mb-3">
                            <div class="col-lg-4 o_light_label">
                                Configuration Status
                            </div>

                            <div class="col-lg-8">
                                <field name="laundry_config_status"
                                       readonly="1"
                                       nolabel="1"/>
                            </div>
                        </div>

                        <button name="action_open_laundry_pos_config"
                            type="object"
                            string="Open Laundry Configuration"
                            class="btn btn-primary"
                            invisible="not pos_enable_laundry_workflow"/>

                    </div>

                </setting>

            </xpath>

        </field>
    </record>

</odoo>